#include "Generated.xcconfig"

// Production Build Configuration
// Safe to check into version control

// Dart obfuscation — renames identifiers to make reverse engineering harder
DART_OBFUSCATION=true

// Tree-shake icon fonts — removes unused Material Icons glyphs (~200KB savings)
TREE_SHAKE_ICONS=true

// Disable widget creation tracking — production doesn't need this debug overhead
TRACK_WIDGET_CREATION=false

// EXTRA_FRONT_END_OPTIONS removed — --no-causal-async-stacks is not a valid option in current Flutter
